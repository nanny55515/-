<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>برنامج الـ 90 يوم الصحي</title>
    <style>
        :root {
            --bg-color: #121214;
            --card-color: #1a1a1e;
            --text-color: #ffffff;
            --text-muted: #a0a0a5;
            --accent-sport: #00ffcc;
            --accent-food: #ff9f43;
            --accent-done: #2ecc71;
        }

        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 450px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 1px solid #2a2a30;
            padding-bottom: 15px;
        }

        .session-title {
            font-size: 24px;
            font-weight: bold;
            color: var(--accent-sport);
            margin: 5px 0;
        }

        .progress-text {
            color: var(--text-muted);
            font-size: 14px;
        }

        .section-title {
            font-size: 18px;
            margin: 15px 0 10px 0;
            padding-right: 5px;
        }

        .sport-title { color: var(--accent-sport); border-right: 3px solid var(--accent-sport); }
        .food-title { color: var(--accent-food); border-right: 3px solid var(--accent-food); }

        .item-card {
            background-color: var(--card-color);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            transition: background 0.2s;
            border: 1px solid #222226;
        }

        .item-card:active {
            background-color: #222228;
        }

        .item-info {
            flex-grow: 1;
            padding-left: 10px;
        }

        .item-name {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .item-details {
            font-size: 13px;
            color: var(--text-muted);
        }

        .checkbox {
            width: 24px;
            height: 24px;
            border: 2px solid var(--text-muted);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .item-card.checked .checkbox {
            background-color: var(--accent-done);
            border-color: var(--accent-done);
        }

        .item-card.checked .checkbox::after {
            content: "✓";
            color: white;
            font-size: 14px;
            font-weight: bold;
        }

        .item-card.checked .item-name {
            text-decoration: line-through;
            color: var(--text-muted);
        }

